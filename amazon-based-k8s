#!/bin/bash
set -e

echo "Disabling swap..."
sudo swapoff -a
sleep 2

echo "Loading necessary kernel modules for Kubernetes networking..."
cat <<EOF | sudo tee /etc/modules-load.d/k8s.conf
overlay
br_netfilter
EOF

sudo modprobe overlay
sudo modprobe br_netfilter
sleep 2

echo "Setting sysctl parameters for networking..."
cat <<EOF | sudo tee /etc/sysctl.d/k8s.conf
net.bridge.bridge-nf-call-iptables  = 1
net.bridge.bridge-nf-call-ip6tables = 1
net.ipv4.ip_forward                 = 1
EOF

sudo sysctl --system
lsmod | grep br_netfilter || true
lsmod | grep overlay || true
sleep 2

echo "Installing containerd from Amazon Linux repo..."
sudo dnf update -y
sleep 2

sudo dnf install -y containerd
sleep 2

sudo mkdir -p /etc/containerd
containerd config default | \
  sed -e 's/SystemdCgroup = false/SystemdCgroup = true/' \
      -e 's@sandbox_image = "registry.k8s.io/pause:3.6"@sandbox_image = "registry.k8s.io/pause:3.9"@' \
  | sudo tee /etc/containerd/config.toml >/dev/null

sudo systemctl enable --now containerd
sleep 2

sudo systemctl is-active containerd
sleep 2

echo "Adding Kubernetes repo (v1.29 RPM)..."
cat << 'EOF' | sudo tee /etc/yum.repos.d/kubernetes.repo
[kubernetes]
name=Kubernetes
baseurl=https://pkgs.k8s.io/core:/stable:/v1.29/rpm/
enabled=1
gpgcheck=1
gpgkey=https://pkgs.k8s.io/core:/stable:/v1.29/rpm/repodata/repomd.xml.key
EOF

sleep 2

echo "Installing Kubernetes components (kubelet, kubeadm, kubectl)..."
sudo dnf install -y kubelet kubeadm kubectl --disableexcludes=kubernetes
sleep 2

sudo systemctl enable kubelet
sleep 2

echo "Kubernetes setup completed on Amazon Linux 2023."
